<IfModule mod_rewrite.c>
  RewriteEngine On
  # App at site root (e.g. zlomky.tagline.cz). If you ever deploy in a subfolder, set this to that path + trailing slash.
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  RewriteRule ^ index.html [L]
</IfModule>
